    "firebase-functions": "^7.2.5",
    "googleapis": "^173.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "eslint-config-google": "^0.14.0",
    "eslint-plugin-import": "^2.32.0",
    "firebase-functions-test": "^3.5.0",
    "globals": "^17.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0"
  },
  "private": true
